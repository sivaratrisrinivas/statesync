{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "functions": {
        "api/**": {
            "includeFiles": "server/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/((?!api).*)",
            "destination": "/index.html"
        }
    ]
}